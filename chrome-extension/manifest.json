{
  "manifest_version": 3,
  "name": "nost Bridge",
  "version": "1.0.0",
  "description": "nost와 브라우저 탭을 연동합니다",
  "permissions": ["tabs", "activeTab"],
  "host_permissions": ["http://127.0.0.1:14502/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "nost",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
